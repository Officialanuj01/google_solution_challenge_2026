{
  "displayName": "Predelix Delivery Bot",
  "defaultLanguageCode": "en",
  "timeZone": "America/New_York",
  "description": "Automated delivery confirmation calling bot for Predelix. Calls customers to confirm delivery time slots and capture delivery instructions.",
  "startFlow": "Default Start Flow",
  "speechToTextSettings": {
    "enableSpeechAdaptation": true
  },
  "webhookConfig": {
    "genericWebService": {
      "uri": "${CLOUD_RUN_URL}/api/delivery/webhook",
      "httpMethod": "POST",
      "requestHeaders": {
        "Content-Type": "application/json"
      }
    }
  },
  "flows": [
    {
      "displayName": "Default Start Flow",
      "description": "Main delivery confirmation call flow",
      "pages": [
        {
          "displayName": "Start Page",
          "entryFulfillment": {
            "messages": [
              {
                "text": {
                  "text": [
                    "Hello! I'm calling on behalf of Predelix. We are delivering your order today. At what time will you be available to receive the delivery?"
                  ]
                }
              }
            ],
            "webhook": "predelix-webhook",
            "tag": "greeting"
          },
          "form": {
            "parameters": [
              {
                "displayName": "preferred_time",
                "entityType": "@sys.time",
                "required": true,
                "fillBehavior": {
                  "initialPromptFulfillment": {
                    "messages": [
                      {
                        "text": {
                          "text": ["What time works best for you? For example, morning, afternoon, or a specific time like 2 PM."]
                        }
                      }
                    ]
                  },
                  "repromptEventHandlers": [
                    {
                      "event": "sys.no-match-1",
                      "triggerFulfillment": {
                        "messages": [
                          {
                            "text": {
                              "text": ["I didn't catch that. Could you please tell me a preferred delivery time?"]
                            }
                          }
                        ]
                      }
                    }
                  ]
                }
              }
            ]
          },
          "transitionRoutes": [
            {
              "condition": "$page.params.status = 'FINAL'",
              "targetPage": "Capture Instructions"
            }
          ]
        },
        {
          "displayName": "Capture Instructions",
          "entryFulfillment": {
            "messages": [
              {
                "text": {
                  "text": [
                    "Thank you. I've noted your preferred delivery time. Do you have any specific delivery instructions? For example, leave at the door, ring the bell, or call before arriving."
                  ]
                }
              }
            ],
            "webhook": "predelix-webhook",
            "tag": "capture_time"
          },
          "form": {
            "parameters": [
              {
                "displayName": "delivery_instructions",
                "entityType": "@sys.any",
                "required": false,
                "fillBehavior": {
                  "initialPromptFulfillment": {
                    "messages": [
                      {
                        "text": {
                          "text": ["Any special instructions for the delivery driver?"]
                        }
                      }
                    ]
                  }
                }
              }
            ]
          },
          "transitionRoutes": [
            {
              "condition": "$page.params.status = 'FINAL'",
              "targetPage": "End Session"
            }
          ]
        },
        {
          "displayName": "End Session",
          "entryFulfillment": {
            "messages": [
              {
                "text": {
                  "text": [
                    "Thank you! Your delivery preferences have been recorded. We'll deliver your order at your requested time. Goodbye!"
                  ]
                }
              }
            ],
            "webhook": "predelix-webhook",
            "tag": "capture_instructions"
          }
        }
      ],
      "eventHandlers": [
        {
          "event": "sys.no-match-default",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["I'm sorry, I didn't understand that. Could you please repeat?"]
                }
              }
            ],
            "webhook": "predelix-webhook",
            "tag": "fallback"
          }
        },
        {
          "event": "sys.no-input-default",
          "triggerFulfillment": {
            "messages": [
              {
                "text": {
                  "text": ["I couldn't hear you. Please say your preferred delivery time."]
                }
              }
            ]
          }
        }
      ]
    }
  ],
  "intents": [
    {
      "displayName": "delivery.confirm.time",
      "trainingPhrases": [
        "morning", "afternoon", "evening", "10 AM", "2 PM", "after 5", "anytime",
        "in the morning", "in the afternoon", "between 9 and 12", "around noon",
        "before 6 PM", "I'll be home at 3"
      ]
    },
    {
      "displayName": "delivery.instructions",
      "trainingPhrases": [
        "leave at the door", "ring the bell", "call me before", "leave with neighbor",
        "no instructions", "that's fine", "just leave it", "knock loudly",
        "leave it at reception", "I'll be home"
      ]
    },
    {
      "displayName": "delivery.confirm.yes",
      "trainingPhrases": [
        "yes", "sure", "okay", "that's fine", "great", "perfect", "sounds good"
      ]
    }
  ],
  "telephonyConfig": {
    "note": "Configure Dialogflow CX Telephony Gateway or CCAI Platform in GCP Console. Point the phone number to this agent. The webhook URL is your Cloud Run service URL + /api/delivery/webhook"
  },
  "setupInstructions": {
    "step1": "Import this config into Dialogflow CX Console at https://dialogflow.cloud.google.com/cx",
    "step2": "Set DIALOGFLOW_AGENT_ID env var to the agent ID from the console",
    "step3": "Configure the webhook URL to point to your Cloud Run service",
    "step4": "Enable Cloud Telephony Gateway or integrate with Twilio CCAI"
  }
}
