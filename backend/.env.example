# ──────────────────────────────────────────────
# Predelix Backend — Environment Configuration
# ──────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# ── GCP Core ─────────────────────────────────
GCP_PROJECT_ID=predelix-prod
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ── Vertex AI ────────────────────────────────
VERTEX_ENDPOINT_ID=your-vertex-endpoint-id
VERTEX_MODEL_ID=your-vertex-model-id

# ── Twilio (Delivery Bot) ───────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app

# ── Gemini API ───────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-pro

# ── Cloud Storage ────────────────────────────
GCS_UPLOAD_BUCKET=predelix-uploads

# ── Authentication ───────────────────────────
JWT_ACCESS_SECRET=your-strong-access-secret-key
JWT_REFRESH_SECRET=your-strong-refresh-secret-key
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/predelix

# ── Google OAuth ─────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
