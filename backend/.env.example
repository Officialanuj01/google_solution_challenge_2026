# ──────────────────────────────────────────────
# Pulse Backend — Environment Configuration
# ──────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# ── PULSE (HuggingFace Gradio Space) ─────────
GRADIO_SPACE_URL=%%%%%%%%%%%%%%%%%%%

# ── Twilio (Delivery Bot) ───────────────────
TWILIO_ACCOUNT_SID=################
TWILIO_AUTH_TOKEN=#################
TWILIO_PHONE_NUMBER=##################
# ^ Get your trial number from: console.twilio.com → Phone Numbers → Active Numbers
TWILIO_WHATSAPP_NUMBER=whatsapp:+1XXXXXXXXXX
# ^ Twilio WhatsApp sandbox sender format. Replace with your approved WhatsApp-enabled Twilio number or sandbox sender.
PUBLIC_BASE_URL=##################

# ── Gemini API ───────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-pro

# ── Authentication ───────────────────────────
JWT_ACCESS_SECRET=your-strong-access-secret-key
JWT_REFRESH_SECRET=your-strong-refresh-secret-key
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/Pulse

# ── Google OAuth ─────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
